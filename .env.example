# ciris-status configuration. Every probe target is optional — leave a *_URL
# blank to omit that component (matches CIRISLens's behaviour).

# --- service ---
STATUS_LISTEN_ADDR=0.0.0.0:8200
STATUS_DB_PATH=/data/status.db
STATUS_POLL_SECONDS=60

# --- local providers (optional; these retire with Lens) ---
# DATABASE_URL=postgres://user:pass@host:5432/db   # local "postgresql" (TCP probe)
# GRAFANA_URL=http://grafana:3000                   # local "grafana" (/api/health)

# --- US region ---
# US_BILLING_URL=https://billing.us.example/        # probes {url}/v1/status
# US_PROXY_URL=https://proxy.us.example/
# VULTR_HEALTH_URL=https://health.us.example/        # infra host health

# --- EU region ---
# EU_BILLING_URL=https://billing.eu.example/
# EU_PROXY_URL=https://proxy.eu.example/
# HETZNER_HEALTH_URL=https://health.eu.example/

# --- container registry (defaults to ghcr.io; 401 = up) ---
# GHCR_HEALTH_URL=https://ghcr.io/v2/

# --- external search providers (each needs its _HEALTH_URL to be probed) ---
# COST SAFETY: by default these are probed KEYLESS (reachability only — no API
# key sent, so NO billable call). Brave bills health checks; the old Lens code had
# to disable it. Keyless is safe for all of them.
# Send the live key (BILLABLE for some providers) ONLY by opting in per provider
# with <PREFIX>_HEALTH_AUTH=true, and ONLY if that provider's health endpoint is
# free. Leave BRAVE_HEALTH_AUTH unset/false.
# EXA_HEALTH_URL=...      EXA_API_KEY=...      # EXA_HEALTH_AUTH=true (if free)
# BRAVE_HEALTH_URL=...    BRAVE_API_KEY=...    # keep keyless — Brave bills health checks
# SERPER_HEALTH_URL=...   SERPER_API_KEY=...
# TAVILY_HEALTH_URL=...   TAVILY_API_KEY=...

# --- fabric node (Node B) — ONLY when built with `--features fabric` ----------
# Turns ciris-status into a real fabric node: Flow B signs + emits probe results
# as CEG `health:liveness` `scores` attestations, and Flow A reads `capacity:*`
# from the corpus to build the public roster. ALL of the core (non-peer) vars
# must be set or the flows stay disabled (the binary runs as the plain prober;
# roster stays empty).
#
# Node B owns its OWN corpus — a B-LOCAL file, distinct from Node A's. A's
# capacity:* data arrives by REPLICATION (below), NOT by sharing A's DB file.
# STATUS_CORPUS_DSN=sqlite:///var/lib/ciris-status/corpus.db  # Node B's OWN corpus (distinct from A)
# STATUS_NODE_KEY_ID=ciris-status-monitor      # this node's Ed25519 identity key_id
# STATUS_NODE_KEY_PATH=/secrets/ed25519.seed   # 32-byte raw Ed25519 seed (chmod 600)
# STATUS_NODE_PQC_KEY_ID=ciris-status-monitor-pqc
# STATUS_NODE_PQC_KEY_PATH=/secrets/mldsa65.seed  # ML-DSA-65 seed (hybrid signing)
# Map region-key → the keyed CIRIS service node's key_id we attest about
# (providers/regions fold in as evidence_refs, NOT as separate subjects):
# STATUS_SERVICE_KEYS=us=k_service_us,eu=k_service_eu
#
# --- Round-2 federation peer (Node A, the lens node) — OPTIONAL ---------------
# When set, Node B registers A's key (admission), emits a DIRECTED
# `consent:replication:v1` grant at A, and starts A<->B anti-entropy replication
# over an HTTP transport (Attestation kind, carries both directions). Unset ⇒ B
# runs solo: self-registers + emits its own health:liveness, no replication.
# key_id + A's self-signed SignedKeyRecord are REQUIRED to enable the peer leg.
# v8.8.0 (CIRISPersist#234 §5.6.8.15): the admission gate now requires A's OWN
# proof-of-possession record (A exports it; B can no longer fabricate A's row
# from raw pubkeys). STATUS_PEER_A_KEY_RECORD is A's exported SignedKeyRecord as
# serde_json (single line) — both nodes are on persist v8.8.0 so the shape matches.
# STATUS_PEER_A_KEY_ID=ciris-server-steward
# STATUS_PEER_A_KEY_RECORD={"record":{"key_id":"ciris-server-steward","pubkey_ed25519_base64":"...","pubkey_ml_dsa_65_base64":"...","algorithm":"hybrid","identity_type":"steward",...}}
# STATUS_PEER_A_INBOUND_URL=https://server.ciris.ai/edge/inbound  # A's replication intake (outbound leg)
# STATUS_REPLICATION_LISTEN=0.0.0.0:8201   # B's /edge/inbound bind (where A pushes frames)
#
# (Node B logs its OWN SignedKeyRecord as JSON at boot — hand THAT to A as A's
#  corresponding peer-config artifact; the contract is symmetric.)
