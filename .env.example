# ciris-status configuration. Every probe target is optional — leave a *_URL
# blank to omit that component (matches CIRISLens's behaviour).

# --- service ---
STATUS_LISTEN_ADDR=0.0.0.0:8200
STATUS_DB_PATH=/data/status.db
STATUS_POLL_SECONDS=60

# --- local providers (optional; these retire with Lens) ---
# DATABASE_URL=postgres://user:pass@host:5432/db   # local "postgresql" (TCP probe)
# GRAFANA_URL=http://grafana:3000                   # local "grafana" (/api/health)

# --- US region ---
# US_BILLING_URL=https://billing.us.example/        # probes {url}/v1/status
# US_PROXY_URL=https://proxy.us.example/
# VULTR_HEALTH_URL=https://health.us.example/        # infra host health

# --- EU region ---
# EU_BILLING_URL=https://billing.eu.example/
# EU_PROXY_URL=https://proxy.eu.example/
# HETZNER_HEALTH_URL=https://health.eu.example/

# --- container registry (defaults to ghcr.io; 401 = up) ---
# GHCR_HEALTH_URL=https://ghcr.io/v2/

# --- external search providers (each needs its _HEALTH_URL to be probed) ---
# COST SAFETY: by default these are probed KEYLESS (reachability only — no API
# key sent, so NO billable call). Brave bills health checks; the old Lens code had
# to disable it. Keyless is safe for all of them.
# Send the live key (BILLABLE for some providers) ONLY by opting in per provider
# with <PREFIX>_HEALTH_AUTH=true, and ONLY if that provider's health endpoint is
# free. Leave BRAVE_HEALTH_AUTH unset/false.
# EXA_HEALTH_URL=...      EXA_API_KEY=...      # EXA_HEALTH_AUTH=true (if free)
# BRAVE_HEALTH_URL=...    BRAVE_API_KEY=...    # keep keyless — Brave bills health checks
# SERPER_HEALTH_URL=...   SERPER_API_KEY=...
# TAVILY_HEALTH_URL=...   TAVILY_API_KEY=...
