# ciris-status configuration. ciris-status IS a ciris-server node + a
# StatusAdapter, so env splits in two: the NODE vars (CIRIS_SERVER_* /
# CIRIS_PEER_B_*, read by ciris-server) and the STATUS ADAPTER vars (probe
# targets / cadence, read here). Every probe target is optional — leave a *_URL
# blank to omit that component (matches CIRISLens's behaviour).

# --- node (ciris-server) ------------------------------------------------------
# The node binds the Reticulum port; the read API + the status routers bind
# port + 1 (default :4243). The corpus DB + the node's minted Ed25519/ML-DSA-65
# identity live under CIRIS_HOME — no seed files to manage by hand.
# CIRIS_HOME=/data/ciris
# CIRIS_SERVER_LISTEN_ADDR=0.0.0.0:4242
# CIRIS_SERVER_KEY_ID=ciris-server      # the node's federation key_id (health:liveness attester)
# How this node REACHES the lens node (Node A) on the Reticulum mesh — REQUIRED
# for cross-host replication (the CIRIS_PEER_B_* key below is identity, not a
# network path). Comma-separated host:port.
# CIRIS_SERVER_BOOTSTRAP_PEERS=lens.ciris.ai:4242

# --- status adapter (probe targets + cadence) ---------------------------------
STATUS_DB_PATH=/data/status.db          # uptime-history SQLite (NOT the node corpus)
STATUS_POLL_SECONDS=60                   # probe + roster-refresh + history cadence

# --- local providers (optional; these retire with Lens) ---
# DATABASE_URL=postgres://user:pass@host:5432/db   # local "postgresql" (TCP probe)
# GRAFANA_URL=http://grafana:3000                   # local "grafana" (/api/health)

# --- US region ---
# US_BILLING_URL=https://billing.us.example/        # probes {url}/v1/status
# US_PROXY_URL=https://proxy.us.example/
# VULTR_HEALTH_URL=https://health.us.example/        # infra host health

# --- EU region ---
# EU_BILLING_URL=https://billing.eu.example/
# EU_PROXY_URL=https://proxy.eu.example/
# HETZNER_HEALTH_URL=https://health.eu.example/

# --- container registry (defaults to ghcr.io; 401 = up) ---
# GHCR_HEALTH_URL=https://ghcr.io/v2/

# --- external search providers (each needs its _HEALTH_URL to be probed) ---
# COST SAFETY: by default these are probed KEYLESS (reachability only — no API
# key sent, so NO billable call). Brave bills health checks; the old Lens code had
# to disable it. Keyless is safe for all of them.
# Send the live key (BILLABLE for some providers) ONLY by opting in per provider
# with <PREFIX>_HEALTH_AUTH=true, and ONLY if that provider's health endpoint is
# free. Leave BRAVE_HEALTH_AUTH unset/false.
# EXA_HEALTH_URL=...      EXA_API_KEY=...      # EXA_HEALTH_AUTH=true (if free)
# BRAVE_HEALTH_URL=...    BRAVE_API_KEY=...    # keep keyless — Brave bills health checks
# SERPER_HEALTH_URL=...   SERPER_API_KEY=...
# TAVILY_HEALTH_URL=...   TAVILY_API_KEY=...

# --- consent:replication peer (Node A / the lens node) — OPTIONAL -------------
# Peering is ciris-server's job now (the CIRIS_PEER_B_* slot). When set, the node
# registers the peer's key (admission), emits a DIRECTED `consent:replication:v1`
# grant, and runs A<->B anti-entropy replication so the peer's `capacity:*` flows
# INTO this node's OWN corpus. Unset ⇒ this node runs solo (self-registers +
# emits its own health:liveness, no replication; roster stays empty until rows
# are replicated/seeded).
#
# v8.8.0 (CIRISPersist#234 §5.6.8.15): the admission gate requires the peer's OWN
# proof-of-possession record (the peer exports it; neither side can fabricate the
# other's row from raw pubkeys). CIRIS_PEER_B_KEY_RECORD is the peer's exported
# SignedKeyRecord as serde_json (single line) — both nodes are on persist v9.0.3
# so the shape matches.
# CIRIS_PEER_B_KEY_ID=ciris-server-steward
# CIRIS_PEER_B_KEY_RECORD={"record":{"key_id":"ciris-server-steward","pubkey_ed25519_base64":"...","pubkey_ml_dsa_65_base64":"...","algorithm":"hybrid","identity_type":"steward",...}}
#
# (This node logs its OWN SignedKeyRecord as JSON at boot — hand THAT to the peer
#  as its corresponding peer-config artifact; the contract is symmetric.)
#
# The full peering/transport env reference (data dirs, NAT-traversal toggles,
# bootstrap peers, etc.) is ciris-server's src/config.rs.
